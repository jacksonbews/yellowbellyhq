rules_version = '2';
// ================================================================
// YELLOW BELLY HQ — Storage rules (uploaded PDF documents)
// Team members can read; only admins can upload/delete.
// ================================================================
service firebase.storage {
  match /b/{bucket}/o {
    function onTeam() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/emails/$(request.auth.token.email.lower()));
    }
    function canUpload() {
      return request.auth != null &&
        (request.auth.token.email.lower() in ['nikkichadwickbews@gmail.com', 'jackson@yellowbellyphoto.com'] ||
         firestore.get(/databases/(default)/documents/emails/$(request.auth.token.email.lower())).data.role in ['owner-dev', 'owner']);
    }
    // uploaded PDF documents
    match /docs/{file} {
      allow read: if onTeam();
      allow write: if canUpload();
    }
    // bug/idea ticket screenshots
    match /tickets/{file} {
      allow read: if onTeam();
      allow write: if canUpload();
    }
  }
}
