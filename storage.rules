rules_version = '2';
// ================================================================
// YELLOW BELLY HQ — Storage rules (uploaded PDF documents)
// Team members can read; only admins can upload/delete.
// ================================================================
service firebase.storage {
  match /b/{bucket}/o {
    match /docs/{file} {
      allow read: if request.auth != null &&
        firestore.exists(/databases/(default)/documents/emails/$(request.auth.token.email.lower()));
      allow write: if request.auth != null &&
        (request.auth.token.email.lower() == 'nikkichadwickbews@gmail.com' ||
         firestore.get(/databases/(default)/documents/emails/$(request.auth.token.email.lower())).data.role in ['owner-dev', 'owner']);
    }
  }
}
